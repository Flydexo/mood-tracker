# ─── Docker Compose environment variables ────────────────────────────────────
# Copy this file to .env.docker (gitignored) and fill in your values.
# Pass it to docker compose with: docker compose --env-file .env.docker up -d
#
# When deploying with Dokploy, set these as environment variables in the
# Dokploy service settings — do NOT commit the filled-in file.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=mood
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=mood_tracker

# ── AdonisJS backend ──────────────────────────────────────────────────────────
TZ=UTC
LOG_LEVEL=info

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_KEY=change_me_32_char_minimum_secret_key

# Public URL of the backend (used for self-referencing links)
APP_URL=https://api.yourdomain.com

# Static API key expected from the Chrome extension
API_KEY=change_me_api_key

# Comma-separated Chrome extension origin(s) for CORS
# e.g. chrome-extension://abcdefghijklmnopqrstuvwxyz123456
CORS_ORIGIN=


