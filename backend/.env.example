# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=your-app-key-min-32-chars-here-please
APP_URL=http://${HOST}:${PORT}

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@localhost:5432/mood_tracker

# API authentication (single static key for the Chrome extension)
API_KEY=your-secret-api-key-here

# CORS - comma-separated allowed origins
# CORS_ORIGIN=chrome-extension://your-extension-id

# ─── Docker / production notes ────────────────────────────────────────────────
# When running inside a container:
#   HOST must be 0.0.0.0 (not localhost) so the server binds to all interfaces
#   PORT should match the EXPOSE directive in the Dockerfile (8080)
#   DATABASE_URL should point to the db service name, e.g.:
#     postgresql://mood:password@db:5432/mood_tracker
# See .env.docker.example for the full Docker Compose variable reference.
